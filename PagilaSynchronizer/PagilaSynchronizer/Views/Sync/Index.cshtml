@{
    ViewData["Title"] = "Sincronizador Pagila";
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>Sincronizador Pagila - TBD2</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 30px;
            background-color: #f0f0f0;
        }

        h2 {
            color: #333;
        }

        .info {
            margin-bottom: 20px;
            font-size: 14px;
            color: #555;
        }

        .estado-box {
            background: white;
            border: 1px solid #ccc;
            padding: 10px;
            margin-bottom: 20px;
            width: 400px;
        }

        .estado-box p {
            margin: 4px 0;
            font-size: 13px;
        }

        .conectado { color: green; font-weight: bold; }
        .desconectado { color: red; font-weight: bold; }

        .botones {
            margin-bottom: 20px;
        }

        button {
            padding: 8px 20px;
            margin-right: 10px;
            font-size: 14px;
            cursor: pointer;
        }

        #btnSyncIn {
            background-color: #4a90d9;
            color: white;
            border: none;
        }

        #btnSyncOut {
            background-color: #5cb85c;
            color: white;
            border: none;
        }

        button:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        #mensajeCargando {
            font-size: 13px;
            color: #888;
            display: none;
            margin-top: 5px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            background: white;
            font-size: 13px;
        }

        table th {
            background-color: #ddd;
            padding: 8px;
            text-align: left;
            border: 1px solid #ccc;
        }

        table td {
            padding: 7px 8px;
            border: 1px solid #ccc;
        }

        .ok { color: green; }
        .error { color: red; }

        h3 {
            margin-bottom: 8px;
            font-size: 15px;
        }
    </style>
</head>
<body>
    
    <div class="estado-box">
        <p>MASTER (PostgreSQL): <span id="estadoMaster">Verificando...</span></p>
        <p>SLAVE (SQL Server): <span id="estadoSlave">Verificando...</span></p>
    </div>

    <div class="botones">
        <button id="btnSyncIn" onclick="ejecutarSync('in')">Sync IN</button>
        <button id="btnSyncOut" onclick="ejecutarSync('out')">Sync OUT</button>
    </div>

    <p id="mensajeCargando">Ejecutando sincronizacion, por favor espere...</p>

    <h3>Log de resultados</h3>
    <table>
        <thead>
            <tr>
                <th>Hora</th>
                <th>Operacion</th>
                <th>Tabla</th>
                <th>Filas</th>
                <th>Estado</th>
                <th>Mensaje</th>
            </tr>
        </thead>
        <tbody id="logBody">
            <tr>
                <td colspan="6" style="color:#999; text-align:center;">No hay registros todavia.</td>
            </tr>
        </tbody>
    </table>

<script>
    async function verificarEstado() {
        try {
            const res = await fetch('/Sync/Status');
            const data = await res.json();

            const master = document.getElementById('estadoMaster');
            const slave = document.getElementById('estadoSlave');

            master.textContent = data.master.connected ? 'Conectado' : 'Sin conexion';
            master.className = data.master.connected ? 'conectado' : 'desconectado';

            slave.textContent = data.slave.connected ? 'Conectado' : 'Sin conexion';
            slave.className = data.slave.connected ? 'conectado' : 'desconectado';
        } catch {
            document.getElementById('estadoMaster').textContent = 'Error';
            document.getElementById('estadoSlave').textContent = 'Error';
        }
    }

    async function ejecutarSync(tipo) {
        const btnIn = document.getElementById('btnSyncIn');
        const btnOut = document.getElementById('btnSyncOut');
        const msg = document.getElementById('mensajeCargando');
        const url = tipo === 'in' ? '/Sync/SyncIn' : '/Sync/SyncOut';

        btnIn.disabled = true;
        btnOut.disabled = true;
        msg.style.display = 'block';

        try {
            const res = await fetch(url, { method: 'POST' });
            const resultados = await res.json();
            agregarLog(resultados);
        } catch (err) {
            agregarLog([{
                success: false,
                tableName: '-',
                rowsAffected: 0,
                operation: tipo.toUpperCase(),
                message: err.message
            }]);
        } finally {
            btnIn.disabled = false;
            btnOut.disabled = false;
            msg.style.display = 'none';
        }
    }

    function agregarLog(resultados) {
        const tbody = document.getElementById('logBody');

        const vacio = tbody.querySelector('td[colspan]');
        if (vacio) vacio.parentElement.remove();

        const hora = new Date().toLocaleTimeString('es-HN');

        resultados.forEach(r => {
            const fila = document.createElement('tr');
            fila.innerHTML = `
                <td>${hora}</td>
                <td>${r.operation}</td>
                <td>${r.tableName}</td>
                <td>${r.rowsAffected}</td>
                <td class="${r.success ? 'ok' : 'error'}">${r.success ? 'OK' : 'ERROR'}</td>
                <td>${r.message}</td>
            `;
            tbody.insertBefore(fila, tbody.firstChild);
        });
    }

    verificarEstado();
    setInterval(verificarEstado, 30000);
</script>

</body>
</html>
